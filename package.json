{
  "name": "workstatus-electron-app",
  "version": "1.2.5",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "deploy": "electron-builder --publish always"
  },
  "build": {
    "appId": "com.hublog.app",
    "productName": "Hublog",
    "files": [
      "**/*"
    ],
    "win": {
      "target": "nsis",
      "icon": "images/hublog_1.ico"
    },
    "mac": {
      "target": "dmg",
      "icon": "images/hublog_1.ico"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": true,
      "allowToChangeInstallationDirectory": false,
      "installerIcon": "images/hublog_1.ico",
      "uninstallerIcon": "images/hublog_1.ico",
      "installerHeaderIcon": "images/hublog_1.ico"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "hublog-frontend",
        "repo": "Workstatus-Electron-App"
      }
    ]
  },
  "devDependencies": {
    "electron": "^30.5.1",
    "electron-builder": "^26.8.1",
    "electron-reloader": "^1.2.3"
  },
  "dependencies": {
    "axios": "^1.15.1",
    "dotenv": "^17.4.2",
    "electron-updater": "^6.8.3",
    "get-windows": "^9.3.0"
  }
}
